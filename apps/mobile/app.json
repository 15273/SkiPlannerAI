{
  "expo": {
    "name": "skiMate",
    "slug": "skimate",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skimate.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.skimate.app"
    },
    "scheme": "skimate",
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
