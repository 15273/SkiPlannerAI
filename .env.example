# ──────────────────────────────────────────────────────────────
# SkiPlannerAI — environment variables template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── FastAPI backend ───────────────────────────────────────────
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Amadeus (flight search) ──────────────────────────────────
# Get API keys at: https://developers.amadeus.com/
# Flights endpoint degrades gracefully if keys are missing.
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
# "test.api.amadeus.com" for sandbox, "api.amadeus.com" for production
AMADEUS_HOSTNAME=test.api.amadeus.com

# ── Mobile app (Expo) ─────────────────────────────────────────
# URL the mobile app uses to reach the API.
# Local dev with simulator:  http://localhost:8000
# Physical device on LAN:    http://192.168.1.10:8000
# Staging:                   https://api-staging.skimate.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mendikalish@localhost:5433/skiplanner

# ── Map providers ─────────────────────────────────────────────
# Mapbox public token — get at https://account.mapbox.com/
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token_here
# Google Maps API key (alternative to Mapbox)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
