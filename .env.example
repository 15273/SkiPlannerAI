# ──────────────────────────────────────────────────────────────
# SkiPlannerAI — environment variables template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── FastAPI backend ───────────────────────────────────────────
# Runtime environment: development | staging | production
API_ENV=
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins
# Dev: http://localhost:8081,http://localhost:19006
# Staging/Prod: https://skimate.app,https://www.skimate.app
CORS_ORIGINS=

# ── Amadeus (flight search) ──────────────────────────────────
# Get API keys at: https://developers.amadeus.com/
# Flights endpoint degrades gracefully if keys are missing.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
#
# AMADEUS_HOSTNAME controls which Amadeus environment is targeted:
#   Development / CI : AMADEUS_HOSTNAME=test.api.amadeus.com  (default)
#   Production       : AMADEUS_HOSTNAME=api.amadeus.com
#
# IMPORTANT — production keys:
#   Production keys require a *separate* Amadeus app registration at
#   https://developers.amadeus.com/ (the test-app keys do NOT work in prod).
#   Store production credentials exclusively in GitHub Actions secrets:
#     AMADEUS_CLIENT_ID      → Settings → Secrets → Actions
#     AMADEUS_CLIENT_SECRET  → Settings → Secrets → Actions
#   Never commit production keys to this file or to .env.
AMADEUS_HOSTNAME=

# ── PostgreSQL + PostGIS ──────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Local example: postgresql+asyncpg://skiplanner:skiplanner@localhost:5433/skiplanner
# Staging/Prod: inject via environment or GitHub Actions secret
DATABASE_URL=

# ── Mobile app (Expo) ─────────────────────────────────────────
# URL the mobile app uses to reach the API.
# Local dev with simulator:   http://localhost:8000
# Physical device on LAN:     http://192.168.1.10:8000
# Staging:                    https://api-staging.skimate.app
EXPO_PUBLIC_API_BASE_URL=

# Staging API base URL — used in Expo staging build profiles (eas.json)
# and injected as a GitHub Actions secret for CI staging builds.
STAGING_API_BASE_URL=

# ── Map providers ─────────────────────────────────────────────
# Mapbox public token — get at https://account.mapbox.com/
# Restrict the token to your domain/bundle ID in the Mapbox console.
MAPBOX_PUBLIC_TOKEN=
# Google Maps API key (alternative to Mapbox).
# Restrict to your app bundle ID and enabled APIs.
GOOGLE_MAPS_API_KEY=
